# ════════════════════════════════════════════════════════════════
# FinTrack — Environment Configuration
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in YOUR OWN project credentials.
# The .env file is gitignored — your keys stay safe.
#
# See README.md → "For Developers" for setup instructions.
# ════════════════════════════════════════════════════════════════

# ── Firebase (https://console.firebase.google.com) ────────────
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_DATABASE_URL=https://your_project.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_PATH=firebase_service_account.json

# ── Supabase (https://supabase.com) ───────────────────────────
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
